# ── Anthropic ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model used for AI-generated SMS/WhatsApp replies. Default if unset: claude-sonnet-4-6
# See https://docs.anthropic.com/en/docs/about-claude/models for the full model list.
# More capable (higher cost): claude-opus-4-8
# Faster and cheaper:         claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Twilio ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX   # Your Twilio number (E.164 format)
OWNER_PHONE=+1XXXXXXXXXX           # Where to send urgent SMS alerts

# ── Upstash Redis (required — conversation state & dedup) ─
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets (optional — call/SMS log) ───────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-bot@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ── Internal test endpoint (keep secret, never share publicly) ───────────
# Used by POST /api/test/inbound to simulate inbound customer messages without Twilio.
TEST_WEBHOOK_SECRET=your-long-random-secret-here

# ── Pilot inbox (password gate) ──────────────────────────
# Single shared password for the /inbox pilot UI and its /api/inbox/* routes.
# POST /api/inbox/login exchanges this for an HttpOnly session cookie; middleware
# guards the inbox against requests without a valid cookie. Rotating this value
# invalidates all existing sessions. Generate with: openssl rand -hex 32
INBOX_PASSWORD=your-long-random-inbox-password-here

# ── Webhook (production only) ─────────────────────────────
# Set to your Vercel URL so Twilio signature validation uses the right host.
# Example: https://your-app.vercel.app/api/twilio/incoming-sms
WEBHOOK_URL=https://YOUR-APP.vercel.app/api/twilio/incoming-sms

# ── Meta WhatsApp Cloud API ───────────────────────────────
# Configure in Meta Developer Console → WhatsApp → Configuration
META_WEBHOOK_VERIFY_TOKEN=your-long-random-verify-token-here
# App Secret — found in Meta Developer Console → App Settings → Basic → App Secret
# Used to verify X-Hub-Signature-256 on every incoming webhook POST.
META_WHATSAPP_APP_SECRET=your-app-secret-here
META_WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_WHATSAPP_PHONE_NUMBER_ID=1234567890123456
META_GRAPH_API_VERSION=v21.0

# ── Clinic identity ───────────────────────────────────────
# Used in bot persona and owner-alert team reference.
# Default if unset: "the clinic" (produces "Our clinic team will follow up shortly")
CLINIC_NAME=Aurea Aesthetic Clinic

# Primary service name used in stage fallbacks and service normalization.
# Use the language your customers write in (English or Turkish).
# Default if unset: "laser hair removal"
CLINIC_PRIMARY_SERVICE=laser hair removal

# ── Booking link (optional) ───────────────────────────────
# Sent once when a lead reaches the complete stage.
CLINIC_BOOKING_URL=https://your-clinic.com/book

# Optional custom text for the booking link message.
# Use {url} as a placeholder for the booking URL.
# Default if unset: "You can complete your appointment request here: {url}"
CLINIC_BOOKING_LINK_MESSAGE=

# ── Clinic defaults (optional) ────────────────────────────
# Optional default clinic location used when a customer does not provide one.
CLINIC_DEFAULT_LOCATION=Main clinic

# ── Daily summary email ────────────────────────────────────
# Resend API key — create a free account at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Owner email address for daily lead summary delivery.
OWNER_EMAIL=owner@yourclinic.com

# Secret used to authenticate the cron route (GET /api/cron/daily-summary).
# Vercel sends this automatically as: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=your-long-random-secret-here

# Sender email address for daily summaries.
# Must be a verified domain in your Resend account.
# Use "onboarding@resend.dev" for testing (sends to Resend account owner only).
RESEND_FROM_EMAIL=RandevuFlow <noreply@yourdomain.com>

# ── Meta compliance layer (ban protection) ────────────────
# All thresholds are optional — safe defaults shown. The compliance gate
# (lib/compliance.ts + lib/outboundSend.ts) enforces these deterministically
# in front of EVERY patient-facing outbound send.

# 24h customer-service window. Free-form sends are blocked once
# now - lastInboundAt >= this many hours. Default: 24
COMPLIANCE_WINDOW_HOURS=24

# Pacing floor between consecutive sends in the same thread (seconds).
# The gate waits out the remainder instead of dropping. Default: 3
COMPLIANCE_THREAD_MIN_GAP_SECONDS=3

# Hard cap on outbound sends per inbound patient message (bot reply +
# booking handoff = 2). Bot replies are additionally capped at 1. Default: 2
COMPLIANCE_MAX_SENDS_PER_INBOUND=2

# Per-tenant outbound token bucket, well under Meta's 20 msg/s coexistence
# cap. Halved automatically when quality is YELLOW. Default: 5
COMPLIANCE_TENANT_RATE_PER_SECOND=5

# Coexistence inactivity nudge: flag tenants idle >= this many days via the
# /api/cron/inactivity-check route (operator alert only, never messages
# patients). Coexistence disconnects at ~13-14 days. Default: 10
COMPLIANCE_INACTIVITY_NUDGE_DAYS=10

# Emergency kill switch: set to "true" to trip the circuit breaker and stop
# ALL bot WhatsApp sends immediately (per-tenant Redis flag also available
# via setManualBreaker). Default: unset (off)
COMPLIANCE_FORCE_CIRCUIT_OPEN=
